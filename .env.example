# ── Required ─────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# ── Substack Publishing (optional) ──────────────────────────────
# One-click publish to Substack. Get your cookie:
# F12 → Application → Cookies → substack.com → copy substack.sid value
# SUBSTACK_COOKIE=s%3A...your_substack_sid_value...
# SUBSTACK_URL=https://yourname.substack.com
